{% extends 'base.html.twig' %}

{% block title %}Ajouter un auteur{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">✍️ Ajouter un nouvel auteur</h1>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card shadow p-4">

        {{ form_start(formulaire,{ attr: { novalidate: 'novalidate' } }) }}

            {{ form_row(formulaire.nom) }}
            {{ form_row(formulaire.prenom) }}
            {{ form_row(formulaire.biographie) }}
            {{ form_row(formulaire.nationalite) }}

     {{ form_row(formulaire.enregistrer) }}

        {{ form_end(formulaire) }}

    </div>

</div>

{% endblock %}