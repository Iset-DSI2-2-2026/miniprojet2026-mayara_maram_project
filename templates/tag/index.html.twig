{% extends 'base.html.twig' %}

{% block content %}

<h1 class="mb-4">🏷️ Liste des tags</h1>

<a href="{{ path('app_tag_nouveau') }}" class="btn btn-primary mb-3">
    ➕ Ajouter un tag
</a>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Couleur</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
    {% for tag in tags %}
        <tr>
            <td>
                <span class="badge" style="background-color: {{ tag.couleur }}">
                    {{ tag.nom }}
                </span>
            </td>

            <td>{{ tag.couleur }}</td>

            <td>
                <form method="post" action="{{ path('app_tag_supprimer', {'id': tag.id}) }}"
                      onsubmit="return confirm('Supprimer ce tag ?');">

                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">

                    <button class="btn btn-danger btn-sm">
                        🗑️ Supprimer
                    </button>
                </form>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="3" class="text-center">Aucun tag trouvé</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}