{% extends 'base.html.twig' %}

{% block title %}Liste des livres{% endblock %}

{% block body %}

<h1>📚 Liste des livres</h1>

<table class="table table-striped mt-4">
    <thead class="table-dark">
        <tr>
            <th>Image</th>
            <th>Titre</th>
            <th>Auteur</th>
            <th>Genre</th>
            <th>Pages</th>
            <th>Statut</th>
            <th>Tags</th>
        </tr>
    </thead>

    <tbody>
    {% for livre in livres %}
        <tr>
            <td>
                {% if livre.imageName %}
                    <img src="/uploads/livres/{{ livre.imageName }}" width="60">
                {% endif %}
            </td>

            <td>{{ livre.titre }}</td>

            <td>
                {{ livre.auteur.nom }} {{ livre.auteur.prenom }}
            </td>

            <td>
                <span class="badge" style="background-color: {{ livre.genre.couleur }}">
                    {{ livre.genre.nom }}
                </span>
            </td>

            <td>{{ livre.nbPages }}</td>

            <td>
                {% if livre.disponible %}
                    <span class="badge bg-success">🟢 Disponible</span>
                {% else %}
                    <span class="badge bg-danger">🔴 Indisponible</span>
                {% endif %}
            </td>

            <td>
                {% for tag in livre.tags %}
                    <span class="badge" style="background-color: {{ tag.couleur }}">
                        {{ tag.nom }}
                    </span>
                {% endfor %}
            </td>
        </tr>
    {% endfor %}
    </tbody>

</table>

{% endblock %}