{% extends 'base.html.twig' %}

{% block body %}

<div class="container mt-4">

    <div class="card shadow p-4">

        <h1 class="mb-3">📘 {{ livre.titre }}</h1>

        {# 🖼️ Image #}
        {% if livre.imageName %}
            <img src="{{ asset('uploads/livres/' ~ livre.imageName) }}"
                 class="img-fluid mb-3"
                 style="max-width: 300px;">
        {% endif %}

        <p><strong>Résumé :</strong> {{ livre.resume }}</p>
        <p><strong>ISBN :</strong> {{ livre.isbn }}</p>
        <p><strong>Nombre de pages :</strong> {{ livre.nbPages }}</p>

        <p>
            <strong>Date de publication :</strong>
            {{ livre.datePublication|date('d/m/Y') }}
        </p>

        {# 👤 Auteur #}
        <p>
            <strong>Auteur :</strong>
            <a href="#">{{ livre.auteur.nom }} {{ livre.auteur.prenom }}</a>
        </p>

        {# 🎭 Genre badge couleur #}
        <p>
            <strong>Genre :</strong>
            <span class="badge"
                  style="background-color: {{ livre.genre.couleur }}">
                {{ livre.genre.nom }}
            </span>
        </p>

        {# 🏷️ Tags #}
        <p>
            <strong>Tags :</strong>
            {% for tag in livre.tags %}
                <span class="badge me-1"
                      style="background-color: {{ tag.couleur }}">
                    {{ tag.nom }}
                </span>
            {% else %}
                <span class="text-muted">Aucun tag</span>
            {% endfor %}
        </p>

        {# 🟢 Disponibilité #}
        <p>
            {% if livre.disponible %}
                <span class="badge bg-success">🟢 Disponible</span>
            {% else %}
                <span class="badge bg-danger">🔴 Indisponible</span>
            {% endif %}
        </p>

        <hr>

        {# 🔘 ACTIONS #}
      <div class="d-flex gap-2">

    {# ✏️ Modifier (propriétaire ou admin) #}
    {% if app.user and (app.user == livre.ajoutePar or is_granted('ROLE_ADMIN')) %}
        <a href="{{ path('app_livre_modifier', {id: livre.id}) }}"
           class="btn btn-warning">
            ✏️ Modifier
        </a>
    {% endif %}

    {# 🗑️ Supprimer (propriétaire ou admin) #}
    {% if app.user and (app.user == livre.ajoutePar or is_granted('ROLE_ADMIN')) %}
        <form method="post"
              action="{{ path('app_livre_supprimer', {id: livre.id}) }}"
              onsubmit="return confirm('Voulez-vous vraiment supprimer ce livre ?');">

            <input type="hidden"
                   name="_token"
                   value="{{ csrf_token('supprimer_' ~ livre.id) }}">

            <button class="btn btn-danger">
                🗑️ Supprimer
            </button>
        </form>
    {% endif %}

    {# ➕ Ajouter (bibliothécaire seulement) #}
    {% if is_granted('ROLE_BIBLIOTHECAIRE') %}
        <a href="{{ path('app_livre_nouveau') }}" class="btn btn-success">
            ➕ Ajouter
        </a>
    {% endif %}

    {# 📚 Retour #}
    <a href="{{ path('app_livres') }}" class="btn btn-secondary">
        ⬅ Retour
    </a>

</div>

    </div>

</div>

{% endblock %}