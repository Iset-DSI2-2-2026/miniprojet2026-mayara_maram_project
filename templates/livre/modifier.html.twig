{% extends 'base.html.twig' %}

{% block title %}Modifier un livre{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">✏️ Modifier le livre</h1>

    {# 🔔 Messages flash #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card shadow p-4">

        {{ form_start(formulaire) }}

            {{ form_row(formulaire.titre) }}
            {{ form_row(formulaire.resume) }}
            {{ form_row(formulaire.isbn) }}
            {{ form_row(formulaire.nbPages) }}
            {{ form_row(formulaire.datePublication) }}
            {{ form_row(formulaire.auteur) }}
            {{ form_row(formulaire.genre) }}
            {{ form_row(formulaire.tags) }}
            {{ form_row(formulaire.disponible) }}
            {{ form_row(formulaire.imageFile) }}

            {{ form_row(formulaire.enregistrer) }}

        {{ form_end(formulaire) }}

    </div>

    {# 🔙 Bouton retour #}
    <a href="{{ path('app_livres') }}" class="btn btn-secondary mt-3">
        ⬅️ Retour à la liste
    </a>

</div>

{% endblock %}